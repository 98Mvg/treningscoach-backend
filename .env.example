# ElevenLabs API Configuration
# Get your API key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Voice Settings
VOICE_DESCRIPTION="Retired elite endurance athlete and coach. Calm, controlled, authoritative. Speaks slowly. Every sentence intentional. No hype. No shouting. Certainty over emotion. Pauses often."

# Optional ElevenLabs audio cache (disabled by default)
# Turn on when you are happy with final voice quality and want cost/latency savings.
TTS_AUDIO_CACHE_ENABLED=false
TTS_AUDIO_CACHE_READ_ENABLED=true
TTS_AUDIO_CACHE_WRITE_ENABLED=true
TTS_AUDIO_CACHE_VERSION=v1
TTS_AUDIO_CACHE_MAX_FILES=1000
TTS_AUDIO_CACHE_MAX_AGE_SECONDS=1209600
TTS_AUDIO_CACHE_CLEANUP_INTERVAL_WRITES=25
TTS_AUDIO_CACHE_DIR=output/cache

# R2 audio pack (optional local-first playback)
R2_BUCKET_NAME=coachi-audio
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
AUDIO_PACK_VERSION=v1

# Anthropic API Configuration (Strategic Brain)
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AI Provider API Keys (optional fallback providers)
# Grok (xAI) is primary by default when priority routing is enabled.
XAI_API_KEY=your_xai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Apple Sign-In token audience validation
# For native iOS Sign in with Apple this is usually your app bundle id.
APPLE_AUTH_ENABLED=true
GOOGLE_AUTH_ENABLED=false
FACEBOOK_AUTH_ENABLED=false
VIPPS_AUTH_ENABLED=false
APPLE_CLIENT_ID=com.mariusgaarder.TreningsCoach
# Optional comma-separated override:
# APPLE_CLIENT_IDS=com.mariusgaarder.TreningsCoach,com.mariusgaarder.TreningsCoach.debug

# Security runtime defaults
# Required in production-like environments. Backend boot now fails fast without it.
JWT_SECRET=replace_me_with_a_real_secret
JWT_ACCESS_TOKEN_MAX_DAYS=7
JWT_REFRESH_TOKEN_MAX_DAYS=7
JWT_SECRET_MAX_AGE_DAYS=90
MOBILE_API_AUTH_REQUIRED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_BACKEND=database
RATE_LIMIT_RETENTION_SECONDS=604800
API_RATE_LIMIT_PER_HOUR=100
AUTH_RATE_LIMIT_PER_HOUR=40
REFRESH_RATE_LIMIT_PER_HOUR=60
CONTINUOUS_RATE_LIMIT_PER_HOUR=1200
AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=5
AUTH_LOGIN_RATE_LIMIT_PER_HOUR=20
AUTH_REGISTER_RATE_LIMIT_PER_10_MINUTES=3
AUTH_REGISTER_RATE_LIMIT_PER_DAY=10
AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=30
AUTH_ME_RATE_LIMIT_PER_MINUTE=60
PROFILE_UPSERT_RATE_LIMIT_PER_MINUTE=20
WORKOUTS_RATE_LIMIT_PER_MINUTE=60
CONTINUOUS_RATE_LIMIT_PER_MINUTE=30
CONTINUOUS_RATE_LIMIT_PER_HOUR=500
COACH_TALK_PREMIUM_RATE_LIMIT_PER_MINUTE=15
COACH_TALK_PREMIUM_RATE_LIMIT_PER_HOUR=25
COACH_TALK_PREMIUM_RATE_LIMIT_PER_DAY=25
COACH_TALK_FREE_RATE_LIMIT_PER_SESSION=3
COACH_TALK_FREE_RATE_LIMIT_PER_DAY=6
CORS_ALLOWED_ORIGINS=https://coachi.app,https://www.coachi.app,http://localhost:3000,http://127.0.0.1:3000
AUTH_BYPASS_FOR_TESTS=false
RATE_LIMIT_BYPASS_FOR_TESTS=false
AUDIO_SIGNATURE_BYPASS_FOR_TESTS=false

# Local runtime storage
INSTANCE_DIR=instance
UPLOAD_DIR=uploads
OUTPUT_DIR=output
WELCOME_ROTATION_STATE_PATH=instance/cache/utterance_rotation_state.json

# Brain Router (env-driven, no code edits required)
ACTIVE_BRAIN=grok
USE_PRIORITY_ROUTING=true
BRAIN_PRIORITY=grok,config
# Global timeout fallback for brains without explicit override
BRAIN_TIMEOUT=1.2
# JSON maps (strings) for provider-specific tuning
BRAIN_TIMEOUTS_JSON={"grok":6.0}
BRAIN_MODE_TIMEOUTS_JSON={}
# Fast Q&A path ("ask coach") defaults
COACH_QA_TIMEOUT_SECONDS=5.0
COACH_QA_MAX_TOKENS=110
COACH_QA_MAX_SENTENCES=5
TALK_STT_ENABLED=false
TALK_STT_QUOTA_COOLDOWN_SECONDS=300
XAI_VOICE_AGENT_ENABLED=false
XAI_VOICE_AGENT_MODEL=grok-3-mini
XAI_VOICE_AGENT_REGION=us-east-1
XAI_VOICE_AGENT_VOICE=Rex
XAI_VOICE_AGENT_MAX_SESSION_SECONDS=300
XAI_VOICE_AGENT_CLIENT_SECRET_URL=https://api.x.ai/v1/realtime/client_secrets
XAI_VOICE_AGENT_WEBSOCKET_URL=wss://api.x.ai/v1/realtime
BRAIN_SLOW_THRESHOLDS_JSON={"grok":6.5}
BRAIN_QUOTA_COOLDOWN_SECONDS=300
BRAIN_RECENT_CUE_WINDOW=4

# Web UI variant served at "/"
# Options: claude | codex
WEB_UI_VARIANT=claude

# Launch behavior locks (stable coaching + Norwegian-first)
DEFAULT_LANGUAGE=no
USE_HYBRID_BRAIN=false
USE_STRATEGIC_BRAIN=false
COACHING_VALIDATION_ENFORCE=true
# Timeline enforcement is safe with zone mode because deterministic zone cues have priority.
BREATHING_TIMELINE_ENFORCE=true
MIN_SIGNAL_QUALITY_TO_FORCE=0.0

# Monetization policy (keep app free now, payment-ready later)
# Launch default: fully free app.
APP_FREE_MODE=true
BILLING_ENABLED=false
PREMIUM_SURFACES_ENABLED=false

# Launch integrations
POSTHOG_ENABLED=false
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=3.0.0
SENTRY_TRACES_SAMPLE_RATE=0.0

# Launch website download links
# Configure these before launch so all CTA buttons go directly to store pages.
APP_STORE_URL=https://apps.apple.com/app/id0000000000
GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.example.coachi
# Optional: Android early-access page or waitlist form URL
ANDROID_EARLY_ACCESS_URL=https://treningscoach-backend.onrender.com/#download

# Waitlist / onboarding email sender (optional; disabled unless explicitly enabled)
EMAIL_SENDING_ENABLED=false
EMAIL_PROVIDER=auto
SUPPORT_EMAIL=AI.Coachi@hotmail.com
EMAIL_FROM=AI.Coachi@hotmail.com
EMAIL_REPLY_TO=AI.Coachi@hotmail.com
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Set to true only if your SMTP provider does not support STARTTLS on the chosen port.
SMTP_DISABLE_TLS=false

# Zone coaching v1 (running/intervals)
DEFAULT_COACHING_STYLE=normal
DEFAULT_INTERVAL_TEMPLATE=4x4
ZONE2_HRR_LOW=0.60
ZONE2_HRR_HIGH=0.70
ZONE2_HRMAX_LOW=0.70
ZONE2_HRMAX_HIGH=0.80
HR_QUALITY_STALE_SECONDS=8
HR_QUALITY_SPIKE_DELTA_BPM=20
HR_QUALITY_SPIKE_WINDOW_SECONDS=2
HR_QUALITY_MIN_CONFIDENCE=0.5
HR_ZONE_HYSTERESIS_BPM=3
HR_ZONE_DWELL_SECONDS=8
MOVEMENT_SCORE_PAUSE_THRESHOLD=0.12
MOVEMENT_SCORE_ACTIVE_THRESHOLD=0.25
MOVEMENT_PAUSE_DWELL_SECONDS=8
MOVEMENT_PAUSE_MIN_HR_DROP_BPM=1.0
MOVEMENT_PAUSE_HR_DROP_MAX_GAP_SECONDS=10
HR_PAUSE_RAPID_DROP_BPM=6
HR_PAUSE_RAPID_DROP_MAX_GAP_SECONDS=8
ZONE_BELOW_PUSH_SUSTAIN_SECONDS=25
ZONE_BELOW_PUSH_MIN_MOVEMENT_SCORE=0.30
ZONE_ABOVE_EASE_SUSTAIN_SECONDS=20
ZONE_ABOVE_EASE_MIN_HR_RISE_BPM=1.5
ZONE_ABOVE_EASE_RISE_MAX_GAP_SECONDS=10
ZONE_SUSTAINED_EVENT_REPEAT_SECONDS=45

# Phase 4: LLM phrasing layer (wording only, not decisions)
ZONE_EVENT_LLM_REWRITE_ENABLED=false
ZONE_EVENT_LLM_REWRITE_TIMEOUT_SECONDS=0.9
ZONE_EVENT_LLM_REWRITE_MAX_WORDS=16
ZONE_EVENT_LLM_REWRITE_MAX_CHARS=120
ZONE_EVENT_LLM_REWRITE_ALLOWED_EVENTS=above_zone,above_zone_ease,below_zone,below_zone_push,in_zone_recovered,phase_change_work,phase_change_rest,phase_change_warmup,phase_change_cooldown,pause_detected,pause_resumed,max_silence_override

# Phase 5: Personalization insights (no event-motor mutation in v1)
ZONE_PERSONALIZATION_ENABLED=true
ZONE_PERSONALIZATION_STORAGE_PATH=instance/zone_personalization.json
ZONE_PERSONALIZATION_MAX_RECOVERY_SAMPLES=24
ZONE_PERSONALIZATION_MAX_SESSION_HISTORY=20

# Unified event router rollout (single source of truth for workout speech)
UNIFIED_EVENT_ROUTER_ENABLED=true
UNIFIED_EVENT_ROUTER_SHADOW=false
IOS_EVENT_SPEECH_ENABLED=true
